# Server-side only -- do NOT prefix with NEXT_PUBLIC_. These are read only in
# Server Components and Route Handlers, never sent to the browser bundle.
# Defaults (used if unset) target local non-Docker dev.
ORDER_API_URL=http://localhost:3000
ANALYTICS_API_URL=http://localhost:3003
FRAUD_API_URL=http://localhost:8005

# Section 8.2's port map assigns this service 3100 — but Next defaults to
# 3000 like every other service here, which collides with order-api if both
# run on the host at once. Set explicitly for local (non-Docker) dev.
PORT=3100
