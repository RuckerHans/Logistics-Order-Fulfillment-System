# Runtime connection — fraud_app role, ASYNC driver (asyncpg)
DATABASE_URL=postgresql+asyncpg://fraud_app:change_me@localhost:5432/postgres

# Migration-only connection — fraud_migrator role, SYNC driver (psycopg2,
# Alembic's runner is sync-only; see Section 6's two-driver note)
MIGRATION_DATABASE_URL=postgresql+psycopg2://fraud_migrator:change_me@localhost:5432/postgres

KAFKA_BROKERS=localhost:9092,localhost:9095,localhost:9096
