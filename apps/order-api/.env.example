# Runtime connection — order_api_app role (USAGE only, no CREATE)
DATABASE_URL=postgres://order_api_app:change_me@localhost:5432/postgres

# Migration-only connection — order_api_migrator role (USAGE + CREATE)
# Never used by the running app; only by `npm run migration:*`.
MIGRATION_DATABASE_URL=postgres://order_api_migrator:change_me@localhost:5432/postgres

RABBITMQ_URL=amqp://localhost:5672
KAFKA_BROKERS=localhost:9092,localhost:9095,localhost:9096

PORT=3000
